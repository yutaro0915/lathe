{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["warn", { "max": 80 }],
    "no-unused-vars": "warn"
  },
  "overrides": [
    {
      "files": ["apps/web/e2e/**/*.spec.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 550, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["apps/web/lib/db.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 1564, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["apps/web/components/FindingsExplorer.tsx"],
      "rules": {
        "max-lines": ["warn", { "max": 963, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["apps/web/scripts/verify-phase2.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 694, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["apps/web/scripts/ingest/providers/claude.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 563, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["packages/mcp/src/service.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 883, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["packages/mcp/src/verify.ts"],
      "rules": {
        "max-lines": ["warn", { "max": 632, "skipBlankLines": true, "skipComments": true }]
      }
    }
  ]
}
