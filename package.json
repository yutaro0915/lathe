{
  "name": "lathe-monorepo",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "preflight": "node scripts/preflight.mjs",
    "gen:design": "node scripts/gen-design.mjs",
    "setup:agent": "sh scripts/setup-lathe-agent.sh",
    "lint:deps": "depcruise --config .dependency-cruiser.js --output-type err-long apps/web/app apps/web/components apps/web/lib packages/mcp/src/server.ts packages/mcp/src/verify.ts packages/acp-client/src packages/shared/src packages/client/src",
    "lint:ox": "oxlint",
    "lint": "pnpm lint:deps && pnpm lint:ox",
    "test": "TZ=UTC node --import tsx --test \"packages/*/src/**/*.test.ts\" \"apps/web/lib/**/*.test.ts\" \"apps/web/components/**/*.test.ts\" \"apps/web/scripts/**/*.test.ts\""
  },
  "devDependencies": {
    "dependency-cruiser": "^16.10.4",
    "oxlint": "^0.16.12",
    "tsx": "^4.22.4"
  }
}
