{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/file-size-guard.mjs pre",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node .claude/hooks/ui-skill-guard.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/file-size-guard.mjs post",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/write-retro.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node .claude/hooks/preflight-stop.mjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
